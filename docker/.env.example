# docker/.env — compose-level variables
# Copy to docker/.env and fill in before running docker compose build / push

# HTTPS port exposed on the host
HTTPS_PORT=5236

# HTTP port exposed on the host (redirects to HTTPS)
HTTP_PORT=5237

# Gemini API key — embedded in the React bundle at build time
# Get one at https://aistudio.google.com/
VITE_GEMINI_API_KEY=AIzaSy...

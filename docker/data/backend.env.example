# backend.env — Avatar backend runtime configuration
# Copy to docker/data/backend.env and fill in before starting the stack.
# This file is mounted read-only into the container — never baked into the image.

# ── Public URL ────────────────────────────────────────────────────────────────
# Where users reach the app (used for CORS, OAuth redirect, and email links)
FRONTEND_ORIGIN=https://172.31.14.92:5236
APP_BASE_URL=https://172.31.14.92:5236

# ── Admin seed account ────────────────────────────────────────────────────────
# This email is auto-approved as admin on first startup
ADMIN_SEED_EMAIL=admin@your-domain.com

# ── Gemini API key (backend — KB ingestion & retrieval) ───────────────────────
GEMINI_API_KEY=AIzaSy...

# ── Neo4j Knowledge Base ──────────────────────────────────────────────────────
# Use the host machine's LAN IP — NOT localhost (resolves to the container itself)
NEO4J_URI=bolt://172.31.14.92:7681
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jadmin

# ── Email ─────────────────────────────────────────────────────────────────────
# Leave SMTP_HOST unset → dev mode (links printed to container logs only)
#
# Gmail via WiFi interface (production setup at HORIBA):
# Corporate network blocks SMTP — route through the WiFi adapter instead.
# The backend container runs with network_mode:host so it can see the host's interfaces.
# SMTP_SOURCE_IFACE: host network interface name for the WiFi adapter.
#   The backend resolves it to an IP automatically at startup.
# SMTP_SOURCE_IP: explicit IP fallback if interface name lookup fails.
# SMTP_FROM must match the Gmail account (or a configured Gmail alias).
# Gmail requires an App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=alexandre.grigoriev@gmail.com
SMTP_PASS=qxcq tcrv mwkm onav
SMTP_FROM="HORIBA AVATAR Platform" <alexandre.grigoriev@gmail.com>
SMTP_SOURCE_IFACE=Internet_Restricted

# ── Cookie ────────────────────────────────────────────────────────────────────
COOKIE_NAME=avatar_session
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# ── Google OAuth (optional) ───────────────────────────────────────────────────
GOOGLE_OAUTH_ENABLED=false
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REDIRECT_URI=https://172.31.14.92:5236/auth/google/callback

# ── LDAP / Active Directory (optional) ───────────────────────────────────────
LDAP_ENABLED=false
# LDAP_URL=ldaps://HFRDC01.jy.fr
# LDAP_DOMAIN=jy.fr
# LDAP_BASE_DN=DC=jy,DC=fr
# LDAP_SEARCH_ATTR=sAMAccountName
# If LDAP uses a self-signed certificate, uncomment:
# NODE_TLS_REJECT_UNAUTHORIZED=0
